# General
TZ=America/Sao_Paulo

# PostgreSQL
POSTGRES_USER=evolution
POSTGRES_PASSWORD=evolution_pass
POSTGRES_DB=evolution
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_pass

# Evolution GO
SERVER_PORT=8080
CLIENT_NAME=evolution
EVOLUTION_HOST=localhost
GLOBAL_API_KEY=replace_with_a_secure_api_key
DATABASE_SAVE_MESSAGES=false
WADEBUG=INFO
LOGTYPE=console
CONNECT_ON_STARTUP=true
WEBHOOKFILES=true

# Evolution GO DB Connections
POSTGRES_AUTH_DB=postgresql://evolution:evolution_pass@postgres:5432/evogo_auth?sslmode=disable
POSTGRES_USERS_DB=postgresql://evolution:evolution_pass@postgres:5432/evogo_users?sslmode=disable

# n8n
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://n8n:5678/
N8N_ENCRYPTION_KEY=replace_with_a_secure_encryption_key

DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_PASSWORD=n8n_pass

QUEUE_BULL_REDIS_HOST=redis
QUEUE_BULL_REDIS_PORT=6379
QUEUE_BULL_REDIS_PASSWORD=redis_pass

# Traefik
ACME_EMAIL=your-email@example.com
